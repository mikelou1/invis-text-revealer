{
  "manifest_version": 3,
  "name": "Invisible Text Revealer",
  "version": "1.1.0",
  "description": "Reveals hidden/invisible text by forcing visible styles and red highlighting.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["<all_urls>"]
}
